# ──────────────────────────────────────────────────────────────
# CoreGrid environment
# ──────────────────────────────────────────────────────────────

# Standalone demo mode (no database / no AI server required).
# Set to "true" to run the full app from the in-memory demo engine — ideal
# for Vercel and local previews. Leave unset/false for a real deployment.
NEXT_PUBLIC_USE_MOCKS=true

# ── Full deployment (only needed when NEXT_PUBLIC_USE_MOCKS is not "true") ──

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coregrid?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"

# Ollama (local AI)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
